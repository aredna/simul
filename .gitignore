# Dependencies and generated extension output
node_modules/
.output/
.wxt/
coverage/
*.crx
*.zip

# Track only the canonical, validated local-install release under dist.
dist/
!dist/
dist/*
!dist/chrome-unpacked/
!dist/chrome-unpacked/**

# Local environment and editor files
.env
.env.*
!.env.example
.envrc
.direnv/
.idea/
.vscode/
.cache/
tmp/
.DS_Store
*.log

# Local credentials and signing material
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.mobileprovision

# BMAD personal configuration; team configuration and artifacts are tracked.
_bmad/config.user.toml
_bmad/custom/*.user.toml

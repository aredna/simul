{
  "name": "simul",
  "version": "0.1.0",
  "private": true,
  "description": "Compare a web page with an on-device Japanese or English translation in Chrome.",
  "type": "module",
  "packageManager": "npm@12.0.1",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=12 <13"
  },
  "scripts": {
    "dev": "wxt",
    "build": "wxt build --browser chrome",
    "artifact:sync": "node tools/extension-artifact.mjs sync",
    "artifact:check": "node tools/extension-artifact.mjs check",
    "zip": "wxt zip --browser chrome",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm test && npm run artifact:check"
  },
  "devDependencies": {
    "linkedom": "0.18.13",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "esbuild": "0.28.1",
    "fx-runner": "1.5.0",
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
